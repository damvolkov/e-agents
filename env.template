# Redis
REDIS_PASSWORD=redis_password
REDIS_ADDRESS=localhost:6379

# LiveKit
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_WS_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret

# STT Service (Faster Whisper)
STT_BASE_URL=http://localhost:4100
STT_WS_URL=ws://localhost:4100/v1/audio/transcriptions
STT_MODEL=Systran/faster-whisper-small
STT_LANGUAGE=en
STT_TIMEOUT=30.0

# TTS Service (Piper via Wyoming)
TTS_HOST=localhost
TTS_PORT=10200
TTS_SAMPLE_RATE=22050
TTS_SILENCE_PADDING=0.15
# Male voices: en_US-ryan-medium, en_US-joe-medium, en_US-john-medium, en_US-hfc_male-medium
# Female voices: en_US-lessac-medium, en_US-amy-medium, en_US-kristin-medium
PIPER_VOICE=en_US-hfc_male-medium

# LLM (Google Gemini)
GEMINI_API_KEY=your_gemini_api_key_here
GOOGLE_API_KEY=your_google_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# Agent Session
AGENT_MAX_TOOL_STEPS=10

# Audio
AUDIO_SAMPLE_RATE=24000
AUDIO_CHANNELS=1

# VAD
VAD_SAMPLE_RATE=16000
VAD_HOP_SIZE=256
VAD_SPEECH_THRESHOLD=0.5
VAD_SILENCE_DURATION=1.5

# Environment
DEBUG=true
ENVIRONMENT=DEV
